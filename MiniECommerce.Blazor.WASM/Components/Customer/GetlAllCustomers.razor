@page "/customers"
@inject CustomerService CustomerService
@inject NavigationManager NavigationManager

<h3>GetlAllCustomers</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="NavigateToCreateCustomer">
        <i class="bi bi-plus-circle"></i> Add New Customer
    </button>
</div>

@if (customers?.Items?.Any() == true)
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in customers.Items)
                        {
                            <tr>
                                <td>@customer.FullName</td>
                                <td>@customer.Phone</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

@code {
    private PagedResult<CustomerDto>? customers;

    protected override async Task OnInitializedAsync()
    {
        customers = await CustomerService.GetCustomersAsync(1, 10);

    }

    private void NavigateToCreateCustomer()
    {
        NavigationManager.NavigateTo("/create-customer");
    }
}
