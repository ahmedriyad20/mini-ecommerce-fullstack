@page "/create-order"
@inject OrderService OrderService
@inject CustomerService CustomerService
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<h3>Create Order</h3>

<hr />
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <div class="mb-3">
                    @* Select the customer *@
                    <label for="customer" class="form-label">Select Customer:</label>
                    <select id="customer" @bind="selectedCustomerId" class="form-select">
                        <option value="">-- Select Customer --</option>
                        @if (customers != null)
                        {
                            @foreach (var customer in customers)
                            {
                                <option value="@customer.Id">@customer.FullName</option>
                            }
                        }
                    </select>
                </div>

                @* Select the products *@
                <h5>Add Products</h5>
                <div class="row mb-3">
                    <div class="col-md-8">
                        <label class="form-label">Product:</label>
                        <select @bind="selectedProductId" class="form-select">
                            <option value="">-- Select Product --</option>
                            @if (products != null)
                            {
                                @foreach (var product in products)
                                {
                                    <option value="@product.Id">@product.Name - @product.Price.ToString("C") (Stock: @product.AvailableQuantity)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Quantity:</label>
                        <input type="number" @bind="selectedQuantity" class="form-control" min="1" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <button type="button" class="btn btn-success w-100" @onclick="AddItem">Add</button>
                    </div>
                </div>

                @* Show all selected order Items  *@
                @if (orderItems.Any())
                {
                    <h5>Order Items</h5>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in orderItems)
                            {
                                var product = products?.FirstOrDefault(p => p.Id == item.ProductId);
                                <tr>
                                    <td>@product?.Name</td>
                                    <td>@item.Quantity</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" @onclick="() => RemoveItem(item)">Remove</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="mt-3">
                    <button type="button" class="btn btn-primary" @onclick="CreateOrderAsync" disabled="@(!CanCreateOrder())">
                        Create Order
                    </button>
                    <a href="/orders" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<CustomerDto>? customers;
    private List<ProductDto>? products;
    private List<CreateOrderItemDto> orderItems = new(); // Items that user added to order

    private string selectedCustomerId = ""; // When user select a customer it will be binded here
    private string selectedProductId = ""; // When user select a product it will be binded here
    private int selectedQuantity = 1;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var customersResult = await CustomerService.GetCustomersAsync(1, 100);
        customers = customersResult?.Items?.ToList();

        var productsResult = await ProductService.GetProductsAsync(1, 100);
        products = productsResult?.Items?.ToList();
    }

    private void AddItem()
    {
        errorMessage = "";

        // To validate that the user selected a product
        if (string.IsNullOrEmpty(selectedProductId))
        {
            errorMessage = "Please select a product.";
            return;
        }

        // To validate that the user selected a quantity
        if (selectedQuantity <= 0)
        {
            errorMessage = "Quantity must be greater than 0.";
            return;
        }

        var productId = Guid.Parse(selectedProductId);

        orderItems.Add(new CreateOrderItemDto(productId, selectedQuantity));

        // Reset selection
        selectedProductId = "";
        selectedQuantity = 1;
    }

    private void RemoveItem(CreateOrderItemDto item)
    {
        orderItems.Remove(item);
        errorMessage = "";
    }

    private bool CanCreateOrder()
    {
        return !string.IsNullOrEmpty(selectedCustomerId) && orderItems.Any();
    }

    private async Task CreateOrderAsync()
    {
        errorMessage = "";

        if (!CanCreateOrder())
        {
            errorMessage = "Please select a customer and add at least one product.";
            return;
        }

        var customerId = Guid.Parse(selectedCustomerId);
        var createOrderDto = new CreateOrderDto(customerId, orderItems);

        var result = await OrderService.CreateOrderAsync(createOrderDto);

        if (result != null)
        {
            NavigationManager.NavigateTo($"/orders/{result.Id}");
        }
        else
        {
            errorMessage = "Failed to create order. Please check stock availability and try again.";
        }
    }
}